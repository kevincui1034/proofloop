# ── Database ──────────────────────────────────────────────────────────
# Local dev: docker compose up -d (Postgres on 54329), then copy to .env.local
DATABASE_URL=postgres://proofjury:proofjury@localhost:54329/proofjury
# Production (Supabase): use the TRANSACTION POOLER url (port 6543) for the
# app runtime; run migrations against the DIRECT/session url (port 5432).
# Managed Postgres needs TLS — it's auto-enabled for non-local hosts.
# DATABASE_SSL=disable        # force TLS off (local only)
# DATABASE_SSL_CA=            # PEM to verify the provider CA strictly

# ── Auth.js ───────────────────────────────────────────────────────────
# AUTH_SECRET: `npx auth secret` (any random string in dev).
AUTH_SECRET=dev-secret-change-me
# GitHub OAuth app (production; omit in dev — use the dev login instead)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Dev-only credentials login (never active in production builds)
AUTH_DEV_LOGIN=1

# ── Proof-file storage ────────────────────────────────────────────────
# "local" writes under dashboard/.data/blob/ (dev + tests).
BLOB_DRIVER=local
# Production: Cloudflare R2 (S3-compatible, private bucket). Set these and
# leave BLOB_DRIVER unset to use R2.
R2_ENDPOINT=            # https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_REGION=auto
# R2_FORCE_PATH_STYLE=true   # true works for both R2 and MinIO

APP_URL=http://localhost:3000
